# Discord Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Instagram Configuration
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Google Configuration
# These values can be found in your Google Cloud Console OAuth 2.0 Client ID settings.
# IMPORTANT: Use "Web Application" client type for hosting on a domain.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_PROJECT_ID=your_google_project_id_here
# The redirect URI must match what you set in GCP. 
# Example: https://uqasocial.null-set.dev/api/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback
